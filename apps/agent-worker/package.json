{
  "name": "@lux/agent-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/server.ts --format esm --dts",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist node_modules coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@lux/agent-runtime": "workspace:*",
    "@lux/contracts": "workspace:*",
    "ai": "^6.0.158",
    "ai-sdk-provider-claude-code": "^3.4.4",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
